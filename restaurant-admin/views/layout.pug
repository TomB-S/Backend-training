//- Structure commune à toutes les pages - toutes les vues héritent de ce fichier
html
  head
    title Administration de plats
    meta(charset="UTF-8")
    //- CSS global partagé par toutes les pages
    style.
      body { font-family: Arial, sans-serif; max-width: 960px; margin: 0 auto; padding: 20px; }
      h1 { text-align: center; }
      table { width: 60%; border-collapse: collapse; margin: 0 auto; }
      th, td { border: 1px solid #ddd; padding: 6px 12px; }
      th { background: #1a3a5c; color: white; }
      a { color: #1a3a5c; }
      .btn { padding: 6px 14px; background: #1a3a5c; color: white; text-decoration: none; border-radius: 4px; }
      .img-welcome { display: block; margin: 0 auto 16px; max-width: 200px; }
      label { display: inline-block; width: 80px; }
      input { padding: 6px; margin: 4px 0; }
  body
    h1 Administration des plats
    //- Zone remplacée par le contenu de chaque vue enfant
    block contenu